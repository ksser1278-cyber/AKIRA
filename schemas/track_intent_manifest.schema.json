{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Engine Track Intent Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artist_id",
    "record_count",
    "ready_for_conditioning_count",
    "tie_in_count",
    "collaboration_count",
    "intent_label_counts",
    "usage_role_counts"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "artist_id": { "type": "string" },
    "record_count": { "type": "integer" },
    "ready_for_conditioning_count": { "type": "integer" },
    "tie_in_count": { "type": "integer" },
    "collaboration_count": { "type": "integer" },
    "intent_label_counts": { "type": "object" },
    "usage_role_counts": { "type": "object" },
    "spotify_snapshot_path": { "type": ["string", "null"] },
    "curated_records_path": { "type": "string" }
  }
}
