{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Engine Lyric Web Scrape Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artist_id",
    "artist_name",
    "language",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artist_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "artist_name": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "collection_method": {
      "type": "string"
    },
    "raw_output_dir": {
      "type": "string"
    },
    "manifest_output_path": {
      "type": "string"
    },
    "respect_robots_txt": {
      "type": "boolean"
    },
    "user_agent": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          },
          "track_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "title": {
            "type": "string"
          },
          "extraction_mode": {
            "type": "string",
            "enum": [
              "auto",
              "selector",
              "json_ld",
              "heuristic"
            ]
          },
          "site_preset": {
            "type": "string",
            "enum": [
              "uta_net",
              "utaten",
              "petitlyrics"
            ]
          },
          "selector": {
            "type": "string"
          },
          "selectors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "remove_selectors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
