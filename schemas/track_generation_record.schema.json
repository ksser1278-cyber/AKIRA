{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Track Generation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "track_identity",
    "source_status",
    "lyric_profile",
    "sound_profile",
    "prompt_readiness"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "track_generation_record"
    },
    "track_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "artist_id",
        "canonical_title"
      ],
      "properties": {
        "track_id": {
          "type": "string",
          "minLength": 1
        },
        "artist_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_title": {
          "type": "string",
          "minLength": 1
        },
        "mode_candidates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "source_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_quality",
        "lyric_technique_quality",
        "sound_profile_quality"
      ],
      "properties": {
        "metadata_quality": {
          "type": "string",
          "enum": [
            "seed",
            "partial",
            "reviewed"
          ]
        },
        "lyric_technique_quality": {
          "type": "string",
          "enum": [
            "missing",
            "partial",
            "reviewed"
          ]
        },
        "sound_profile_quality": {
          "type": "string",
          "enum": [
            "missing",
            "partial",
            "reviewed"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "lyric_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_behavior",
        "hook_behavior",
        "emotional_arc",
        "imagery_bank",
        "surface_profile"
      ],
      "properties": {
        "section_behavior": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "hook_behavior": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emotional_arc": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "imagery_bank": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "surface_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sound_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tempo_profile",
        "energy_profile",
        "groove_profile",
        "arrangement_profile",
        "instrumentation_profile",
        "texture_profile",
        "vocal_profile",
        "sound_anchors"
      ],
      "properties": {
        "tempo_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "bpm_estimate": {
              "type": [
                "number",
                "null"
              ]
            },
            "tempo_band": {
              "type": "string"
            },
            "tempo_feel": {
              "type": "string"
            },
            "meter_signature": {
              "type": "string"
            },
            "swing_or_straight": {
              "type": "string"
            }
          }
        },
        "energy_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "global_energy_level": {
              "type": "string"
            },
            "energy_arc_label": {
              "type": "string"
            },
            "peak_section": {
              "type": "string"
            },
            "release_section": {
              "type": "string"
            },
            "drop_presence": {
              "type": "string"
            }
          }
        },
        "groove_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "arrangement_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instrumentation_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "texture_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vocal_profile": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sound_anchors": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "positive",
            "negative"
          ],
          "properties": {
            "positive": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "negative": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "prompt_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suno_prompt_ready",
        "blocking_reasons"
      ],
      "properties": {
        "suno_prompt_ready": {
          "type": "boolean"
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
