{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Supervised Training Sample",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sample_id",
    "schema_version",
    "split",
    "task",
    "input",
    "output",
    "metadata"
  ],
  "properties": {
    "sample_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "split": {
      "type": "string",
      "enum": [
        "train",
        "eval",
        "test",
        "holdout_artist",
        "holdout_mode"
      ]
    },
    "task": {
      "type": "string",
      "enum": [
        "hook_generation",
        "section_generation",
        "chorus_rewrite",
        "final_release_rewrite",
        "full_song_generation"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artist_id",
        "mode_id",
        "language",
        "blueprint",
        "style_constraints"
      ],
      "properties": {
        "artist_id": {
          "type": "string",
          "minLength": 1
        },
        "mode_id": {
          "type": "string",
          "minLength": 1
        },
        "language": {
          "type": "string",
          "const": "ja"
        },
        "title_seed": {
          "type": "string"
        },
        "theme_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blueprint": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "sections",
            "hook_constraints"
          ],
          "properties": {
            "sections": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "section",
                  "line_target"
                ],
                "properties": {
                  "section": {
                    "type": "string",
                    "enum": [
                      "intro",
                      "verse_1",
                      "pre_chorus",
                      "chorus",
                      "verse_2",
                      "pre_chorus_2",
                      "bridge",
                      "chorus_final",
                      "outro"
                    ]
                  },
                  "line_target": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            },
            "hook_constraints": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "title_binding",
                "repetition_pressure",
                "hook_line_target"
              ],
              "properties": {
                "title_binding": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "repetition_pressure": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "hook_line_target": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          }
        },
        "style_constraints": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "surface_rules"
          ],
          "properties": {
            "imagery_atoms": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "forbidden_generic_atoms": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "surface_rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "phonetic_constraints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "short_line_ratio_target": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0
            },
            "open_vowel_release": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "lyrics_markdown"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "lyrics_markdown": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_track_id",
        "source_artist_id",
        "source_tier",
        "rights_status"
      ],
      "properties": {
        "source_track_id": {
          "type": "string",
          "minLength": 1
        },
        "source_artist_id": {
          "type": "string",
          "minLength": 1
        },
        "source_tier": {
          "type": "string",
          "enum": [
            "benchmark_truth",
            "generation_safe",
            "structured_reference",
            "intake_pending"
          ]
        },
        "rights_status": {
          "type": "string",
          "enum": [
            "cleared_for_training",
            "licensed_for_training",
            "internal_only_holdout",
            "not_cleared",
            "unknown"
          ]
        }
      }
    }
  }
}
