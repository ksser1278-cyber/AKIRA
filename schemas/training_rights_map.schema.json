{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Training Rights Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "records"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "track_id",
          "artist_id",
          "rights_status"
        ],
        "properties": {
          "track_id": {
            "type": "string",
            "minLength": 1
          },
          "artist_id": {
            "type": "string",
            "minLength": 1
          },
          "rights_status": {
            "type": "string",
            "enum": [
              "cleared_for_training",
              "licensed_for_training",
              "internal_only_holdout",
              "not_cleared",
              "unknown"
            ]
          },
          "source_basis": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
