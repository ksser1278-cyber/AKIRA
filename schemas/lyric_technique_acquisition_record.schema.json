{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Lyric Technique Acquisition Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "track_identity",
    "metadata_context",
    "acquisition_sources",
    "queue_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "lyric_technique_acquisition_record"
    },
    "track_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "artist_id",
        "canonical_title"
      ],
      "properties": {
        "track_id": { "type": "string", "minLength": 1 },
        "artist_id": { "type": "string", "minLength": 1 },
        "canonical_title": { "type": "string", "minLength": 1 }
      }
    },
    "metadata_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "engine_family",
        "voicebanks",
        "original_platform",
        "original_upload_date"
      ],
      "properties": {
        "producer": { "type": "string" },
        "engine_family": { "type": "string" },
        "voicebanks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "original_platform": { "type": "string" },
        "original_upload_date": { "type": "string" }
      }
    },
    "acquisition_sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vocadb_pages",
        "official_uploads",
        "other_metadata_sources"
      ],
      "properties": {
        "vocadb_pages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "official_uploads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "other_metadata_sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "label",
              "source_type",
              "url"
            ],
            "properties": {
              "label": { "type": "string" },
              "source_type": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      }
    },
    "queue_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "priority",
        "ready_for_lyric_grounding",
        "blocking_flags",
        "next_step"
      ],
      "properties": {
        "priority": { "type": "string" },
        "ready_for_lyric_grounding": { "type": "boolean" },
        "blocking_flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_step": { "type": "string" }
      }
    }
  }
}
