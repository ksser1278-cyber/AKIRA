{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Engine Lyric Source Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artist_id",
    "artist_name",
    "language",
    "source_type",
    "collection_method",
    "tracks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artist_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "artist_name": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "manual_text",
        "manual_markdown",
        "json_export",
        "web_scrape"
      ]
    },
    "collection_method": {
      "type": "string"
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "track_id",
          "title",
          "lyric_path"
        ],
        "properties": {
          "track_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "title": {
            "type": "string"
          },
          "lyric_path": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "source_url": {
            "type": "string"
          },
          "source_site": {
            "type": "string"
          }
        }
      }
    }
  }
}
