{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Rights-Cleared Training Source Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "track_identity",
    "source_package",
    "rights_review",
    "content_assets",
    "training_scope"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "training_source_record"
    },
    "track_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "artist_id",
        "title"
      ],
      "properties": {
        "track_id": {
          "type": "string",
          "minLength": 1
        },
        "artist_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_family",
        "source_locator",
        "evidence_ref"
      ],
      "properties": {
        "source_family": {
          "type": "string",
          "enum": [
            "direct_license",
            "owned_original",
            "partner_corpus",
            "internal_eval_only"
          ]
        },
        "source_locator": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "rights_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rights_status",
        "source_basis",
        "reviewed_at",
        "reviewer"
      ],
      "properties": {
        "rights_status": {
          "type": "string",
          "enum": [
            "cleared_for_training",
            "licensed_for_training",
            "internal_only_holdout",
            "not_cleared",
            "unknown"
          ]
        },
        "source_basis": {
          "type": "string",
          "minLength": 1
        },
        "reviewed_at": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "content_assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lyric_text_ref",
        "section_map_ref"
      ],
      "properties": {
        "lyric_text_ref": {
          "type": "string",
          "minLength": 1
        },
        "section_map_ref": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "metadata_references": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "label",
              "source_type",
              "usage_scope"
            ],
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string"
              },
              "source_type": {
                "type": "string",
                "enum": [
                  "official_page",
                  "official_upload",
                  "vocadb",
                  "vocaloid_wiki",
                  "fan_database",
                  "other"
                ]
              },
              "usage_scope": {
                "type": "string",
                "enum": [
                  "metadata_only",
                  "mode_support",
                  "interpretation_support"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "training_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_tasks"
      ],
      "properties": {
        "allowed_tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "hook_generation",
              "section_generation",
              "chorus_rewrite",
              "final_release_rewrite",
              "full_song_generation"
            ]
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
