{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Sound Profile Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "track_identity",
    "source_paths",
    "review_status",
    "review_context",
    "current_inferred_sound_profile",
    "reviewed_sound_profile"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "sound_profile_review_record"
    },
    "track_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "artist_id",
        "canonical_title"
      ],
      "properties": {
        "track_id": { "type": "string", "minLength": 1 },
        "artist_id": { "type": "string", "minLength": 1 },
        "canonical_title": { "type": "string", "minLength": 1 }
      }
    },
    "source_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generation_record",
        "canonical_metadata"
      ],
      "properties": {
        "generation_record": { "type": "string" },
        "canonical_metadata": { "type": "string" }
      }
    },
    "review_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_state",
        "review_quality",
        "notes"
      ],
      "properties": {
        "review_state": {
          "type": "string",
          "enum": [
            "incoming",
            "accepted",
            "rejected"
          ]
        },
        "review_quality": {
          "type": "string",
          "enum": [
            "pending",
            "reviewed"
          ]
        },
        "notes": { "type": "string" }
      }
    },
    "review_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_sources",
        "blocking_reasons"
      ],
      "properties": {
        "metadata_sources": {
          "type": "array",
          "items": { "type": "object" }
        },
        "blocking_reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "current_inferred_sound_profile": {
      "type": "object"
    },
    "reviewed_sound_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tempo_feel",
        "energy_arc_label",
        "chorus_lift_strategy",
        "arrangement_density_profile",
        "instrumentation_core",
        "texture_markers",
        "vocal_performance_character",
        "safe_positive_sound_anchors",
        "negative_sound_anchors"
      ],
      "properties": {
        "tempo_feel": { "type": "string" },
        "energy_arc_label": { "type": "string" },
        "chorus_lift_strategy": { "type": "string" },
        "arrangement_density_profile": {
          "type": "array",
          "items": { "type": "string" }
        },
        "instrumentation_core": {
          "type": "array",
          "items": { "type": "string" }
        },
        "texture_markers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vocal_performance_character": {
          "type": "array",
          "items": { "type": "string" }
        },
        "safe_positive_sound_anchors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "negative_sound_anchors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
