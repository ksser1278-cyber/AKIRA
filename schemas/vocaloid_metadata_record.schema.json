{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AKIRA Vocaloid Metadata Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "track_identity",
    "canonical_basis",
    "vocal_synthesis",
    "credits",
    "release_context",
    "metadata_sources",
    "collection_status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "record_type": {
      "type": "string",
      "const": "vocaloid_metadata_record"
    },
    "track_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_id",
        "canonical_title"
      ],
      "properties": {
        "track_id": {
          "type": "string",
          "minLength": 1
        },
        "canonical_title": {
          "type": "string",
          "minLength": 1
        },
        "title_variants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "canonical_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "is_vocaloid_canonical",
        "inclusion_basis"
      ],
      "properties": {
        "is_vocaloid_canonical": {
          "type": "boolean"
        },
        "inclusion_basis": {
          "type": "string",
          "enum": [
            "vocaloid_original",
            "synthetic_voice_original",
            "vocadb_canonical",
            "official_canonical",
            "needs_review"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "vocal_synthesis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_family",
        "voicebanks"
      ],
      "properties": {
        "engine_family": {
          "type": "string",
          "enum": [
            "vocaloid",
            "synthesizer_v",
            "cevio",
            "utau",
            "voiceroid_song_culture",
            "mixed",
            "unknown"
          ]
        },
        "voicebanks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "credits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer"
      ],
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "lyricist": {
          "type": "string"
        },
        "composer": {
          "type": "string"
        },
        "arranger": {
          "type": "string"
        },
        "featured_creators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "release_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "original_platform": {
          "type": "string",
          "enum": [
            "youtube",
            "niconico",
            "bilibili",
            "streaming",
            "cd_release",
            "other",
            "unknown"
          ]
        },
        "original_upload_date": {
          "type": "string"
        },
        "album_or_tie_in": {
          "type": "string"
        },
        "variant_relations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "relation_type",
              "title"
            ],
            "properties": {
              "relation_type": {
                "type": "string",
                "enum": [
                  "self_cover",
                  "remake",
                  "remix",
                  "human_vocal_version",
                  "alternate_upload",
                  "other"
                ]
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "metadata_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "source_type",
          "url"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": [
              "official_page",
              "official_upload",
              "vocadb",
              "vocaloid_wiki",
              "fan_database",
              "other"
            ]
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "collection_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_quality",
        "canonical_review_status"
      ],
      "properties": {
        "metadata_quality": {
          "type": "string",
          "enum": [
            "seed",
            "partial",
            "reviewed"
          ]
        },
        "canonical_review_status": {
          "type": "string",
          "enum": [
            "accepted",
            "needs_review",
            "rejected"
          ]
        },
        "corpus_value_tier": {
          "type": "string",
          "enum": [
            "core",
            "supporting",
            "low_value_retained",
            "deferred"
          ]
        },
        "value_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
